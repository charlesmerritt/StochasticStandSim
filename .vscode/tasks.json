{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "uv run",
            "type": "shell",
            "command": "uv run ${file}",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "uv add package",
            "type": "shell",
            "command": "uv add ${input:packageName}",
            "problemMatcher": []
        },
        {
            "label": "uv sync",
            "type": "shell",
            "command": "uv sync",
            "presentation": {
                "reveal": "silent"
            }
        }
    ],
    "inputs": [
        {
            "id": "packageName",
            "type": "promptString",
            "description": "Enter the package name to add"
        }
    ]
}